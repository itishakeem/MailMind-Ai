# Root-level gitignore — covers files that remain at the repo root

# Stale build artefacts (generated by Next.js before the frontend/ restructure)
.next/
node_modules/
next-env.d.ts
*.tsbuildinfo

# Real environment variables — NEVER commit
.env.local
.env.production.local
.env.development.local
.env.test.local

# Google OAuth credentials
*.apps.googleusercontent.com.json

# OS
.DS_Store
Thumbs.db

# Logs
*.log
