# MailMind AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── App URL (used for OpenRouter HTTP-Referer header) ───────────────────────
# Set to your production domain on Vercel, e.g. https://mail-mind-ai-snowy.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose

# ─── Google OAuth (for Gmail send permission) ────────────────────────────────
# Create at: console.cloud.google.com > APIs & Services > Credentials
# Scopes required: https://www.googleapis.com/auth/gmail.send
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Development:
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/callback
# Production: GMAIL_REDIRECT_URI=https://yourdomain.com/api/gmail/callback

# ─── AI (OpenRouter) ─────────────────────────────────────────────────────────
# Get key at: openrouter.ai/keys
# Paid key   : google/gemini-2.5-flash (Pro email generation) + fallback openrouter/auto
# Free key   : google/gemini-2.0-flash-exp:free (agent AI calls — no credits needed)
# OPENROUTER_API_KEY_FREE is optional — if omitted the paid key is used for agent too.
OPENROUTER_API_KEY=sk-or-your-openrouter-key
OPENROUTER_API_KEY_FREE=sk-or-your-openrouter-free-key

# ─── Token Encryption ────────────────────────────────────────────────────────
# 32-byte random hex string for AES-256-GCM Gmail token encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Use a cryptographically random value — never a sequential string.
ENCRYPTION_KEY=your-64-char-hex-string-here

# ─── Cron Job Security ───────────────────────────────────────────────────────
# Random secret to authenticate Vercel Cron Job calls to /api/cron/send-scheduled.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-cron-secret-here

# ─── SMTP Mailer (for OTP emails and contact form notifications) ──────────────
# Gmail account used to send OTP verification and password reset emails.
# Set up a Gmail App Password at: myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the Gmail account)
MAILER_USER=your-gmail@gmail.com
MAILER_APP_PASSWORD=your-16-char-app-password

# ─── Admin Notifications (optional) ─────────────────────────────────────────
# If set, contact form submissions are forwarded to this address via SMTP above.
# APP_NOTIFY_EMAIL=admin@yourdomain.com

# ─── Lemon Squeezy (Payments) ─────────────────────────────────────────────────
# Sign up at: lemonsqueezy.com → Settings → API → New API Key
LEMONSQUEEZY_API_KEY=your_ls_api_key_here

# Store ID: lemonsqueezy.com → Settings → Stores → your store → copy numeric ID
LEMONSQUEEZY_STORE_ID=12345

# Variant ID: your Pro product → Variants → copy the numeric variant ID
LEMONSQUEEZY_PRO_VARIANT_ID=67890

# Webhook secret: lemonsqueezy.com → Settings → Webhooks → New Webhook
# URL: https://yourdomain.com/api/payments/webhook
# Events to enable: subscription_created, subscription_updated, subscription_expired
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret
