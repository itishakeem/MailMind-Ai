# MailMind AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never expose

# ─── Google OAuth (for Gmail send permission) ────────────────────────────────
# Create at: console.cloud.google.com > APIs & Services > Credentials
# Scopes required: https://www.googleapis.com/auth/gmail.send
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/callback
# Production: GMAIL_REDIRECT_URI=https://yourdomain.com/api/gmail/callback

# ─── AI — Primary (OpenRouter / Gemini Flash) ────────────────────────────────
# Get key at: openrouter.ai/keys
# Model: google/gemini-flash-1.5  (~$0.075/1M tokens)
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# ─── AI — Fallback (NVIDIA NIM / Nemotron 3 Super) ──────────────────────────
# Get key at: build.nvidia.com  (200 free requests/day)
# Model: nvidia/nemotron-3-8b-chat-4k-steerlm
NVIDIA_API_KEY=nvapi-your-nvidia-key

# ─── Token Encryption ────────────────────────────────────────────────────────
# 32-byte random hex string for AES-256-GCM Gmail token encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-string-here

# ─── Cron Job Security ───────────────────────────────────────────────────────
# Random secret used to authenticate Vercel Cron Job calls to /api/cron/send-scheduled
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-cron-secret-here
